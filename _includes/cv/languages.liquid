{% comment %}
  Custom languages renderer.
  Supports:
  - RenderCV old style: name / summary
  - JSONResume: language / fluency
  - RenderCV OneLineEntry: label / details
{% endcomment %}

{% for entry in entries %}
  {% capture lang_name %}
    {% if entry.name %}
      {{ entry.name }}
    {% elsif entry.language %}
      {{ entry.language }}
    {% elsif entry.label %}
      {{ entry.label }}
    {% endif %}
  {% endcapture %}

  {% capture fluency %}
    {% if entry.summary %}
      {{ entry.summary }}
    {% elsif entry.fluency %}
      {{ entry.fluency }}
    {% elsif entry.details %}
      {{ entry.details }}
    {% endif %}
  {% endcapture %}

  {{ lang_name | strip }}: {{ fluency | strip }}
{% endfor %}
