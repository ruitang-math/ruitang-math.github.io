{% comment %}
  Custom languages renderer.
  Supports:
  - RenderCV OneLineEntry: label / details
  - RenderCV old style: name / summary
  - JSONResume: language / fluency
{% endcomment %}

<ul>
  {% for entry in entries %}
    {% assign lang_name = entry.label | default: entry.name | default: entry.language %}
    {% assign fluency = entry.details | default: entry.summary | default: entry.fluency %}

    <li>
      <strong>{{ lang_name }}:</strong> {{ fluency }}
    </li>
  {% endfor %}
</ul>
